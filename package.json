{
  "name": "antiyolo",
  "displayName": "AntiYolo: Granular YOLO Extension",
  "description": "Implement a tiered execution engine for Antigravity IDE commands.",
  "version": "0.1.0",
  "publisher": "antigravity",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "antiyolo.runCommand",
        "title": "AntiYolo: Run Agent Command"
      },
      {
        "command": "antiyolo.showDashboard",
        "title": "AntiYolo: Show Dashboard"
      },
      {
        "command": "antiyolo.toggleEnabled",
        "title": "AntiYolo: Toggle Enabled State"
      },
      {
        "command": "antiyolo.toggleRestrictToWorkspace",
        "title": "AntiYolo: Toggle Workspace Safety Boundary"
      },
      {
        "command": "antiyolo.showMenu",
        "title": "AntiYolo: Show Quick Options Menu"
      }
    ],
    "configuration": {
      "title": "AntiYolo Settings",
      "properties": {
        "antiyolo.yoloLevel": {
          "type": "integer",
          "default": 0,
          "minimum": 0,
          "maximum": 3,
          "description": "YOLO execution tier: 0 (Interactive), 1 (Read-Only YOLO), 2 (Scoped YOLO), 3 (Full YOLO)"
        },
        "antiyolo.whitelist": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "List of additional allowed command names/patterns for Level 2 (Scoped YOLO)"
        },
        "antiyolo.timeoutSeconds": {
          "type": "integer",
          "default": 15,
          "minimum": 1,
          "maximum": 60,
          "description": "Maximum execution time in seconds for a single YOLO command."
        },
        "antiyolo.allowPackageOps": {
          "type": "boolean",
          "default": false,
          "description": "Enable auto-execution of package management commands in Level 2."
        },
        "antiyolo.allowedPackageActions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["install", "ci", "update", "uninstall"]
          },
          "default": ["install", "ci", "update"],
          "description": "Allowed package management actions in Level 2."
        },
        "antiyolo.allowTestOps": {
          "type": "boolean",
          "default": false,
          "description": "Enable auto-execution of test execution commands in Level 2."
        },
        "antiyolo.allowedTestActions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["test", "pytest", "jest", "vitest", "mocha", "playwright", "cypress"]
          },
          "default": ["test", "pytest", "jest", "vitest"],
          "description": "Allowed test runners and frameworks in Level 2."
        },
        "antiyolo.allowBuildOps": {
          "type": "boolean",
          "default": false,
          "description": "Enable auto-execution of build and compilation commands in Level 2."
        },
        "antiyolo.allowedBuildActions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["tsc", "build", "make", "gradle", "maven"]
          },
          "default": ["tsc", "build", "make"],
          "description": "Allowed build tools and compilation command types in Level 2."
        },
        "antiyolo.allowGitOps": {
          "type": "boolean",
          "default": false,
          "description": "Enable auto-execution of version control commands in Level 2."
        },
        "antiyolo.allowedGitActions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["add", "commit", "push", "checkout", "branch", "pull", "fetch", "stash", "reset"]
          },
          "default": ["add", "commit", "push", "checkout", "branch", "status", "diff"],
          "description": "Allowed Git operations in Level 2."
        },
        "antiyolo.allowFileOps": {
          "type": "boolean",
          "default": false,
          "description": "Enable auto-execution of file/directory operations in Level 2."
        },
        "antiyolo.allowedFileActions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["mkdir", "touch", "cp", "chmod", "chown"]
          },
          "default": ["mkdir", "touch"],
          "description": "Allowed file operations in Level 2."
        },
        "antiyolo.restrictToWorkspace": {
          "type": "boolean",
          "default": true,
          "description": "Restrict file operations and path arguments to the workspace folder(s) for additional safety."
        },
        "antiyolo.enableDiscord": {
          "type": "boolean",
          "default": false,
          "description": "Send blocked or confirmation-required command alerts to Discord."
        },
        "antiyolo.discordWebhookUrl": {
          "type": "string",
          "default": "",
          "description": "Discord Webhook URL to receive command approval requests."
        },
        "antiyolo.localServerPort": {
          "type": "integer",
          "default": 7788,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Local port to run the HTTP redirect server for Discord approvals."
        },
        "antiyolo.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable AntiYolo command validation and interception globally."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "mocha src/test/suite/**/*.test.ts --require ts-node/register"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^16.11.7",
    "@types/vscode": "^1.75.0",
    "mocha": "^11.7.6",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5"
  }
}
